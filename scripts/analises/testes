import pandas as pd
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
from yellowbrick.cluster import KElbowVisualizer
import matplotlib.pyplot as plt

# 1. Carregar os dados (usando o df_tratado.csv)
df = pd.read_csv('data/df_tratado.csv')
df['purchase_datetime'] = pd.to_datetime(df['date_purchase'] + ' ' + df['time_purchase'])
today = df['purchase_datetime'].max() + pd.Timedelta(days=1)

# 2. Calcular as métricas RFM
rfm_df = df.groupby('fk_contact').agg(
    recency=('purchase_datetime', lambda x: (today - x.max()).days),
    frequency=('nk_ota_localizer_id', 'count'),
    monetary=('gmv_success', 'sum')
).reset_index()

# 3. Escalar as features RFM
features = rfm_df[['recency', 'frequency', 'monetary']]
scaler = StandardScaler()
scaled_features = scaler.fit_transform(features)

# 4. Encontrar o número ideal de clusters com diferentes métricas
# Criar o visualizador com a métrica de inércia (Elbow Method padrão)
model = KMeans(random_state=42, n_init='auto')
visualizer_inertia = KElbowVisualizer(model, k=(2, 10), metric='distortion')
visualizer_inertia.fit(scaled_features)
visualizer_inertia.show(outpath="inertia_plot.png")

# Criar o visualizador com a métrica Silhouette
visualizer_silhouette = KElbowVisualizer(model, k=(2, 10), metric='silhouette')
visualizer_silhouette.fit(scaled_features)
visualizer_silhouette.show(outpath="silhouette_plot.png")

# Criar o visualizador com a métrica Calinski-Harabasz
visualizer_calinski = KElbowVisualizer(model, k=(2, 10), metric='calinski_harabasz')
visualizer_calinski.fit(scaled_features)
visualizer_calinski.show(outpath="calinski_plot.png")